# Supabase (Phase 1+)
# Create a project at https://supabase.com — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMS / WhatsApp notifications (optional — logs to console in dev when unset)
# Twilio: SMS + WhatsApp (recommended)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+1234567890
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Hubtel: SMS only (Ghana) — used when Twilio is not configured
# Dashboard → Authentication → Manage API Keys (client ID + secret)
# Sender nickname (must be approved by Hubtel via support@hubtel.com):
#   - Alphanumeric: max 11 chars (e.g. MOJO, MOJOAPTS)
#   - Or numeric international: max 16 digits (e.g. 233244200001)
#   - No spaces or: _ / & @ . " ' , * # + ! ?
# Docs: https://developers.hubtel.com/docs/business/api_documentation/messaging/sms
# HUBTEL_CLIENT_ID=
# HUBTEL_CLIENT_SECRET=
# HUBTEL_SENDER_ID=MOJO

# Comma-separated: sms, whatsapp (default both)
# NOTIFICATION_CHANNELS=sms,whatsapp

# Optional: use mock data instead of Supabase during migration
# USE_MOCK_DATA=true
