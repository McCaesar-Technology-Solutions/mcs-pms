# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App (required)
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Production secrets (required in production)
MFA_OTP_SECRET=long-random-string-for-production
GUEST_SESSION_SECRET=long-random-string-for-guest-sessions
CRON_SECRET=long-random-string-for-vercel-cron

# Block new owner self-signup after first account (recommended for production)
# DISABLE_PUBLIC_SIGNUP=true

# SMS (at least one provider required in production)
# ARKESEL_API_KEY=
# ARKESEL_SENDER_ID=MOJO

# Twilio Verify (recommended for 2FA — WhatsApp, SMS, and email codes)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# NOTIFICATION_CHANNELS=sms,whatsapp

# Email (required in production if SMS not used for all alerts)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=MOJO Apartments <alerts@yourdomain.com>
# Sandbox (onboarding@resend.dev) only delivers to your Resend account email.
# Verify a domain at resend.com/domains before inviting staff or emailing guests.

# Error monitoring (recommended)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# SMS_PROVIDER=arkesel|hubtel|twilio
# NOTIFICATION_CHANNELS=sms
