{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MOJO Apartments",
  "version": "0.1.0",
  "identifier": "com.mojoapartments.pms",
  "build": {
    "beforeDevCommand": "node scripts/sync-app-url.mjs --dev",
    "beforeBuildCommand": "node scripts/sync-app-url.mjs",
    "devUrl": "http://127.0.0.1:3000/login",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "MOJO Apartments",
        "width": 1366,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "url": "https://mcs-pms.vercel.app/login"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "shortDescription": "MOJO Apartments staff & owner app",
    "longDescription": "Desktop client for the MOJO Apartments property management system. Requires an internet connection.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
