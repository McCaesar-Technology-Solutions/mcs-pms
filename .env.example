# Supabase (Phase 1+)
# Create a project at https://supabase.com — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMS / WhatsApp notifications (optional — logs to console in dev when unset)
#
# Provider priority (auto): Arkesel → Hubtel → Twilio
# Or set explicitly: SMS_PROVIDER=arkesel|hubtel|twilio

# Arkesel: SMS (Ghana) — recommended
# Dashboard → API → generate API key
# Sender ID: max 11 alphanumeric (register in Arkesel dashboard, e.g. MOJO)
# Docs: https://developers.arkesel.com
# ARKESEL_API_KEY=
# ARKESEL_SENDER_ID=MOJO

# Twilio: SMS + WhatsApp (international)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+1234567890
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Hubtel: SMS fallback (Ghana) — if Arkesel is not configured
# HUBTEL_CLIENT_ID=
# HUBTEL_CLIENT_SECRET=
# HUBTEL_SENDER_ID=MOJO

# Comma-separated: sms,whatsapp (default both)
# NOTIFICATION_CHANNELS=sms,whatsapp

# SMS MFA (owner/manager) — uses the same SMS provider above
# MFA_OTP_SECRET=long-random-string-for-production

# Optional: use mock data instead of Supabase during migration
# USE_MOCK_DATA=true
